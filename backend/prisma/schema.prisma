generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String
  firstName       String?       @map("first_name")
  lastName        String?       @map("last_name")
  role            Role          @default(ANALYST)
  isVerified      Boolean       @default(false) @map("is_verified")
  isActive        Boolean       @default(true) @map("is_active")
  planType        String        @default("FREE") @map("plan_type")
  freeReportsUsed Int           @default(0) @map("free_reports_used")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  lastLogin       DateTime?     @map("last_login")
  companies       Company[]
  otpCodes        OtpCode[]
  reports         Report[]
  sessions        Session[]
  inviteTokens    InviteToken[] @relation("creator")

  @@map("users")
}

model InviteToken {
  id          String    @id @default(uuid())
  token       String    @unique
  createdById String    @map("created_by_id")
  usedById    String?   @map("used_by_id")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   User      @relation("creator", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("invite_tokens")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  type      String   @default("EMAIL_VERIFICATION")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_codes")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Company {
  id               String               @id @default(uuid())
  userId           String               @map("user_id")
  name             String
  taxId            String?              @map("tax_id")
  industry         String?
  country          String               @default("ES")
  description      String?
  website          String?
  employees        Int?
  foundedYear      Int?                 @map("founded_year")
  isPublic         Boolean              @default(false) @map("is_public")
  currency         String               @default("EUR")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  deletedAt        DateTime?            @map("deleted_at")
  baseYear         Int?                 @map("base_year")
  businessActivity String?              @map("business_activity")
  isLocked         Boolean              @default(false) @map("is_locked")
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  fiscalYears      FiscalYear[]
  projections      ProjectionScenario[]
  reports          Report[]

  @@index([userId])
  @@map("companies")
}

model FiscalYear {
  id               String            @id @default(uuid())
  companyId        String            @map("company_id")
  year             Int
  quarter          Int               @default(0) @map("quarter")
  startDate        DateTime?         @map("start_date")
  endDate          DateTime?         @map("end_date")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  additionalData   AdditionalData?
  balanceSheet     BalanceSheet?
  calculatedRatios CalculatedRatios?
  cashFlow         CashFlow?
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  incomeStatement  IncomeStatement?

  @@unique([companyId, year, quarter])
  @@index([companyId])
  @@map("fiscal_years")
}

model BalanceSheet {
  id                     String     @id @default(uuid())
  fiscalYearId           String     @unique @map("fiscal_year_id")
  tangibleAssets         Decimal    @default(0) @map("tangible_assets") @db.Decimal(15, 2)
  intangibleAssets       Decimal    @default(0) @map("intangible_assets") @db.Decimal(15, 2)
  financialInvestmentsLp Decimal    @default(0) @map("financial_investments_lp") @db.Decimal(15, 2)
  otherNoncurrentAssets  Decimal    @default(0) @map("other_noncurrent_assets") @db.Decimal(15, 2)
  inventory              Decimal    @default(0) @db.Decimal(15, 2)
  accountsReceivable     Decimal    @default(0) @map("accounts_receivable") @db.Decimal(15, 2)
  otherReceivables       Decimal    @default(0) @map("other_receivables") @db.Decimal(15, 2)
  taxReceivables         Decimal    @default(0) @map("tax_receivables") @db.Decimal(15, 2)
  cashEquivalents        Decimal    @default(0) @map("cash_equivalents") @db.Decimal(15, 2)
  shareCapital           Decimal    @default(0) @map("share_capital") @db.Decimal(15, 2)
  reserves               Decimal    @default(0) @db.Decimal(15, 2)
  retainedEarnings       Decimal    @default(0) @map("retained_earnings") @db.Decimal(15, 2)
  treasuryStock          Decimal    @default(0) @map("treasury_stock") @db.Decimal(15, 2)
  provisionsLp           Decimal    @default(0) @map("provisions_lp") @db.Decimal(15, 2)
  bankDebtLp             Decimal    @default(0) @map("bank_debt_lp") @db.Decimal(15, 2)
  otherLiabilitiesLp     Decimal    @default(0) @map("other_liabilities_lp") @db.Decimal(15, 2)
  provisionsSp           Decimal    @default(0) @map("provisions_sp") @db.Decimal(15, 2)
  bankDebtSp             Decimal    @default(0) @map("bank_debt_sp") @db.Decimal(15, 2)
  accountsPayable        Decimal    @default(0) @map("accounts_payable") @db.Decimal(15, 2)
  taxLiabilities         Decimal    @default(0) @map("tax_liabilities") @db.Decimal(15, 2)
  otherLiabilitiesSp     Decimal    @default(0) @map("other_liabilities_sp") @db.Decimal(15, 2)
  notes                  String?
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  fiscalYear             FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@map("balance_sheets")
}

model IncomeStatement {
  id                   String     @id @default(uuid())
  fiscalYearId         String     @unique @map("fiscal_year_id")
  revenue              Decimal    @default(0) @db.Decimal(15, 2)
  otherOperatingIncome Decimal    @default(0) @map("other_operating_income") @db.Decimal(15, 2)
  costOfSales          Decimal    @default(0) @map("cost_of_sales") @db.Decimal(15, 2)
  staffCostsSales      Decimal    @default(0) @map("staff_costs_sales") @db.Decimal(15, 2)
  adminExpenses        Decimal    @default(0) @map("admin_expenses") @db.Decimal(15, 2)
  staffCostsAdmin      Decimal    @default(0) @map("staff_costs_admin") @db.Decimal(15, 2)
  depreciation         Decimal    @default(0) @db.Decimal(15, 2)
  exceptionalIncome    Decimal    @default(0) @map("exceptional_income") @db.Decimal(15, 2)
  exceptionalExpenses  Decimal    @default(0) @map("exceptional_expenses") @db.Decimal(15, 2)
  financialIncome      Decimal    @default(0) @map("financial_income") @db.Decimal(15, 2)
  financialExpenses    Decimal    @default(0) @map("financial_expenses") @db.Decimal(15, 2)
  incomeTax            Decimal    @default(0) @map("income_tax") @db.Decimal(15, 2)
  notes                String?
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  fiscalYear           FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@map("income_statements")
}

model CashFlow {
  id                String     @id @default(uuid())
  fiscalYearId      String     @unique @map("fiscal_year_id")
  operatingCashFlow Decimal    @default(0) @map("operating_cash_flow") @db.Decimal(15, 2)
  cfEbtAdjustments  Decimal    @default(0) @map("cf_ebt_adjustments") @db.Decimal(15, 2)
  cfWorkingCapital  Decimal    @default(0) @map("cf_working_capital") @db.Decimal(15, 2)
  cfInvestments     Decimal    @default(0) @map("cf_investments") @db.Decimal(15, 2)
  cfDivestments     Decimal    @default(0) @map("cf_divestments") @db.Decimal(15, 2)
  cfDebtObtained    Decimal    @default(0) @map("cf_debt_obtained") @db.Decimal(15, 2)
  cfDebtRepaid      Decimal    @default(0) @map("cf_debt_repaid") @db.Decimal(15, 2)
  cfDividendsPaid   Decimal    @default(0) @map("cf_dividends_paid") @db.Decimal(15, 2)
  notes             String?
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  fiscalYear        FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@map("cash_flows")
}

model AdditionalData {
  id                  String     @id @default(uuid())
  fiscalYearId        String     @unique @map("fiscal_year_id")
  sharesOutstanding   BigInt?    @map("shares_outstanding")
  sharePrice          Decimal?   @map("share_price") @db.Decimal(10, 4)
  dividendsPerShare   Decimal?   @map("dividends_per_share") @db.Decimal(10, 4)
  averageEmployees    Int?       @map("average_employees")
  marketCap           Decimal?   @map("market_cap") @db.Decimal(15, 2)
  enterpriseValue     Decimal?   @map("enterprise_value") @db.Decimal(15, 2)
  notes               String?
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  averageInventory    Decimal?   @map("average_inventory") @db.Decimal(15, 2)
  averageVatPurchases Decimal?   @map("average_vat_purchases") @db.Decimal(5, 2)
  averageVatSales     Decimal?   @map("average_vat_sales") @db.Decimal(5, 2)
  loanAmortization    Decimal?   @map("loan_amortization") @db.Decimal(15, 2)
  materialCost        Decimal?   @map("material_cost") @db.Decimal(15, 2)
  purchases           Decimal?   @map("purchases") @db.Decimal(15, 2)
  fiscalYear          FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@map("additional_data")
}

model CalculatedRatios {
  id                       String     @id @default(uuid())
  fiscalYearId             String     @unique @map("fiscal_year_id")
  currentRatio             Decimal?   @map("current_ratio") @db.Decimal(10, 4)
  quickRatio               Decimal?   @map("quick_ratio") @db.Decimal(10, 4)
  cashRatio                Decimal?   @map("cash_ratio") @db.Decimal(10, 4)
  debtToEquity             Decimal?   @map("debt_to_equity") @db.Decimal(10, 4)
  debtToAssets             Decimal?   @map("debt_to_assets") @db.Decimal(10, 4)
  debtToEbitda             Decimal?   @map("debt_to_ebitda") @db.Decimal(10, 4)
  roe                      Decimal?   @db.Decimal(10, 4)
  roa                      Decimal?   @db.Decimal(10, 4)
  roi                      Decimal?   @db.Decimal(10, 4)
  ros                      Decimal?   @db.Decimal(10, 4)
  grossMargin              Decimal?   @map("gross_margin") @db.Decimal(10, 4)
  ebitdaMargin             Decimal?   @map("ebitda_margin") @db.Decimal(10, 4)
  ebitMargin               Decimal?   @map("ebit_margin") @db.Decimal(10, 4)
  netMargin                Decimal?   @map("net_margin") @db.Decimal(10, 4)
  assetTurnover            Decimal?   @map("asset_turnover") @db.Decimal(10, 4)
  inventoryTurnover        Decimal?   @map("inventory_turnover") @db.Decimal(10, 4)
  daysSalesOutstanding     Decimal?   @map("days_sales_outstanding") @db.Decimal(10, 2)
  daysPayableOutstanding   Decimal?   @map("days_payable_outstanding") @db.Decimal(10, 2)
  daysInventoryOutstanding Decimal?   @map("days_inventory_outstanding") @db.Decimal(10, 2)
  altmanZScore             Decimal?   @map("altman_z_score") @db.Decimal(10, 4)
  springateScore           Decimal?   @map("springate_score") @db.Decimal(10, 4)
  cashConversionCycle      Decimal?   @map("cash_conversion_cycle") @db.Decimal(10, 2)
  capitalizationRatio      Decimal?   @map("capitalization_ratio") @db.Decimal(10, 4)
  revenuePerEmployee       Decimal?   @map("revenue_per_employee") @db.Decimal(15, 2)
  ebitdaPerEmployee        Decimal?   @map("ebitda_per_employee") @db.Decimal(15, 2)
  netIncomePerEmployee     Decimal?   @map("net_income_per_employee") @db.Decimal(15, 2)
  calculatedAt             DateTime   @default(now()) @map("calculated_at")
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @updatedAt @map("updated_at")
  fiscalYear               FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@map("calculated_ratios")
}

model ProjectionScenario {
  id                 String                @id @default(uuid())
  companyId          String                @map("company_id")
  name               String                @default("Proyección Base")
  description        String?
  baseYear           Int                   @map("base_year")
  projectionYears    Int                   @map("projection_years")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  beta               Decimal?              @db.Decimal(8, 4)
  costOfDebt         Decimal?              @map("cost_of_debt") @db.Decimal(8, 4)
  costOfEquity       Decimal?              @map("cost_of_equity") @db.Decimal(8, 4)
  enterpriseValue    Decimal?              @map("enterprise_value") @db.Decimal(15, 2)
  equityValue        Decimal?              @map("equity_value") @db.Decimal(15, 2)
  marketRiskPremium  Decimal?              @map("market_risk_premium") @db.Decimal(8, 4)
  netDebt            Decimal?              @map("net_debt") @db.Decimal(15, 2)
  pvOfTerminalValue  Decimal?              @map("pv_of_terminal_value") @db.Decimal(15, 2)
  riskFreeRate       Decimal?              @map("risk_free_rate") @db.Decimal(8, 4)
  sumPvOfFCFs        Decimal?              @map("sum_pv_of_fcfs") @db.Decimal(15, 2)
  taxRateForWacc     Decimal?              @map("tax_rate_for_wacc") @db.Decimal(8, 4)
  terminalGrowthRate Decimal?              @map("terminal_growth_rate") @db.Decimal(8, 4)
  terminalValue      Decimal?              @map("terminal_value") @db.Decimal(15, 2)
  valuePerShare      Decimal?              @map("value_per_share") @db.Decimal(15, 2)
  wacc               Decimal?              @db.Decimal(8, 4)
  projections        FinancialProjection[]
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("projection_scenarios")
}

model FinancialProjection {
  id                               String             @id @default(uuid())
  scenarioId                       String             @map("scenario_id")
  year                             Int
  revenue                          Decimal            @default(0) @db.Decimal(15, 2)
  revenueGrowthRate                Decimal?           @map("revenue_growth_rate") @db.Decimal(8, 4)
  costOfSales                      Decimal            @default(0) @map("cost_of_sales") @db.Decimal(15, 2)
  costOfSalesGrowthRate            Decimal?           @map("cost_of_sales_growth_rate") @db.Decimal(8, 4)
  otherOperatingExpenses           Decimal            @default(0) @map("other_operating_expenses") @db.Decimal(15, 2)
  otherOperatingExpensesGrowthRate Decimal?           @map("other_operating_expenses_growth_rate") @db.Decimal(8, 4)
  depreciation                     Decimal            @default(0) @db.Decimal(15, 2)
  depreciationGrowthRate           Decimal?           @map("depreciation_growth_rate") @db.Decimal(8, 4)
  exceptionalNet                   Decimal            @default(0) @map("exceptional_net") @db.Decimal(15, 2)
  exceptionalNetGrowthRate         Decimal?           @map("exceptional_net_growth_rate") @db.Decimal(8, 4)
  ebit                             Decimal?           @db.Decimal(15, 2)
  nopat                            Decimal?           @db.Decimal(15, 2)
  grossCashFlow                    Decimal?           @map("gross_cash_flow") @db.Decimal(15, 2)
  workingCapitalInvestment         Decimal            @default(0) @map("working_capital_investment") @db.Decimal(15, 2)
  fixedAssetsInvestment            Decimal            @default(0) @map("fixed_assets_investment") @db.Decimal(15, 2)
  freeCashFlow                     Decimal?           @map("free_cash_flow") @db.Decimal(15, 2)
  notes                            String?
  createdAt                        DateTime           @default(now()) @map("created_at")
  updatedAt                        DateTime           @updatedAt @map("updated_at")
  ebitda                           Decimal?           @db.Decimal(15, 2)
  ebt                              Decimal?           @db.Decimal(15, 2)
  equity                           Decimal            @default(0) @db.Decimal(15, 2)
  equityGrowthRate                 Decimal?           @map("equity_growth_rate") @db.Decimal(8, 4)
  financialCostRate                Decimal?           @map("financial_cost_rate") @db.Decimal(8, 4)
  financialExpenses                Decimal            @default(0) @map("financial_expenses") @db.Decimal(15, 2)
  financialExpensesGrowthRate      Decimal?           @map("financial_expenses_growth_rate") @db.Decimal(8, 4)
  financialIncome                  Decimal            @default(0) @map("financial_income") @db.Decimal(15, 2)
  financialIncomeGrowthRate        Decimal?           @map("financial_income_growth_rate") @db.Decimal(8, 4)
  financialLeverage                Decimal?           @map("financial_leverage") @db.Decimal(10, 4)
  financialNet                     Decimal?           @map("financial_net") @db.Decimal(15, 2)
  financialRisk                    Decimal?           @map("financial_risk") @db.Decimal(10, 4)
  incomeTax                        Decimal            @default(0) @map("income_tax") @db.Decimal(15, 2)
  incomeTaxRate                    Decimal?           @map("income_tax_rate") @db.Decimal(8, 4)
  netIncome                        Decimal?           @map("net_income") @db.Decimal(15, 2)
  operationalRisk                  Decimal?           @map("operational_risk") @db.Decimal(10, 4)
  roa                              Decimal?           @db.Decimal(10, 4)
  roe                              Decimal?           @db.Decimal(10, 4)
  totalAssets                      Decimal            @default(0) @map("total_assets") @db.Decimal(15, 2)
  totalAssetsGrowthRate            Decimal?           @map("total_assets_growth_rate") @db.Decimal(8, 4)
  totalLiabilities                 Decimal            @default(0) @map("total_liabilities") @db.Decimal(15, 2)
  totalLiabilitiesGrowthRate       Decimal?           @map("total_liabilities_growth_rate") @db.Decimal(8, 4)
  ebtVariation                     Decimal?           @map("ebt_variation") @db.Decimal(10, 4)
  financialNetRate                 Decimal?           @map("financial_net_rate") @db.Decimal(8, 4)
  operatingResult                  Decimal?           @map("operating_result") @db.Decimal(15, 2)
  operatingResultVariation         Decimal?           @map("operating_result_variation") @db.Decimal(10, 4)
  revenueVariation                 Decimal?           @map("revenue_variation") @db.Decimal(10, 4)
  discountFactor                   Decimal?           @map("discount_factor") @db.Decimal(10, 6)
  pvOfFCF                          Decimal?           @map("pv_of_fcf") @db.Decimal(15, 2)
  scenario                         ProjectionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, year])
  @@index([scenarioId])
  @@map("financial_projections")
}

model Report {
  id             String       @id @default(uuid())
  companyId      String       @map("company_id")
  userId         String       @map("user_id")
  year           Int
  status         ReportStatus @default(PENDING)
  aiAnalysis     Json?        @map("ai_analysis")
  pdfPath        String?      @map("pdf_path")
  docxPath       String?      @map("docx_path")
  downloadCode   String?      @map("download_code")
  errorMessage   String?      @map("error_message")
  generatedAt    DateTime?    @map("generated_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@map("reports")
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
  CLIENT
}
